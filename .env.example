# Runtime application environment template.
# Copy this file to .env for local runs. GitHub Actions deployment uses the
# matching onprem-live Environment secrets and variables to generate this file
# on the host.

BOT_MODE=LIVE
BOT_API_HOST=0.0.0.0
BOT_API_PORT=8080
BOT_CONTROL_TOKEN=replace-with-operator-control-token
BOT_DATABASE_PATH=/data/bybit-trader.sqlite
BOT_SYMBOL=BTCUSDT
BOT_TIMEFRAMES=M1,M5,M15
BOT_VOLUME_FLOW_COMPOSITE_CONFIG_PATH=/opt/bybit-trader/config/volume-flow-composite-current.json
BOT_STRATEGY_PROFILE_STATE_PATH=/data/strategy-profile-current.txt

BYBIT_API_KEY=replace-with-bybit-api-key
BYBIT_API_SECRET=replace-with-bybit-api-secret
BYBIT_PRIVATE_BASE_URL=https://api.bybit.com
BYBIT_RECV_WINDOW_MILLIS=5000
BYBIT_POSITION_IDX=0
BYBIT_ACCOUNT_TYPE=UNIFIED

BOT_PRIVATE_EXECUTION_ENABLED=true
BOT_EXECUTION_LOOP_ENABLED=false
BOT_EXECUTION_TIMEFRAME=M5
# Runtime loop reconciles/alerts closed PnL first, then evaluates fully closed candles only.
BOT_EXECUTION_CANDLE_LIMIT=18000
BOT_EXECUTION_SYNC_LIMIT=1000
BOT_EXECUTION_ALERT_BATCH_LIMIT=100
BOT_EXECUTION_INTERVAL_SECONDS=300
BOT_EXECUTION_ACCOUNT_EQUITY=660
BOT_EXECUTION_USE_LIVE_EQUITY=true
BOT_EXECUTION_RISK_FRACTION=0.055
BOT_EXECUTION_FEE_RATE=0.0006
BOT_EXECUTION_SLIPPAGE_BUFFER_RATE=0.0002
BOT_EXECUTION_QTY_STEP=0.001
BOT_EXECUTION_MIN_QTY=0.001
BOT_EXECUTION_MAX_QTY=
BOT_EXECUTION_MAX_NOTIONAL=100
BOT_EXECUTION_LEVERAGE=15
BOT_EXECUTION_LIQUIDATION_BUFFER_PCT=0.6

TELEGRAM_ALERTS_ENABLED=false
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_CHAT_ID=replace-with-telegram-chat-id
DISCORD_ALERTS_ENABLED=false
DISCORD_WEBHOOK_URL=replace-with-discord-webhook-url
