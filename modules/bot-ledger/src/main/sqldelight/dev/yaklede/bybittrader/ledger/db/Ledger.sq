CREATE TABLE botState (
  id INTEGER NOT NULL PRIMARY KEY CHECK (id = 1),
  mode TEXT NOT NULL,
  updated_at TEXT NOT NULL,
  heartbeat_at TEXT
);

CREATE TABLE marketCandles (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  symbol TEXT NOT NULL,
  timeframe TEXT NOT NULL,
  opened_at TEXT NOT NULL,
  open TEXT NOT NULL,
  high TEXT NOT NULL,
  low TEXT NOT NULL,
  close TEXT NOT NULL,
  volume TEXT NOT NULL,
  source_timestamp TEXT NOT NULL
);

CREATE UNIQUE INDEX marketCandles_symbol_timeframe_openedAt_idx
ON marketCandles(symbol, timeframe, opened_at);

CREATE TABLE signals (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  strategy TEXT NOT NULL,
  symbol TEXT NOT NULL,
  side TEXT NOT NULL,
  score INTEGER NOT NULL,
  grade TEXT NOT NULL,
  reason_codes TEXT NOT NULL,
  accepted INTEGER NOT NULL,
  rejection_reason TEXT,
  created_at TEXT NOT NULL
);

CREATE TABLE orders (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  exchange_order_id TEXT,
  client_order_id TEXT NOT NULL UNIQUE,
  signal_id INTEGER,
  side TEXT NOT NULL,
  order_type TEXT NOT NULL,
  order_status TEXT NOT NULL,
  intended_risk TEXT NOT NULL,
  created_at TEXT NOT NULL
);

CREATE TABLE fills (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  order_id INTEGER NOT NULL,
  fill_price TEXT NOT NULL,
  quantity TEXT NOT NULL,
  fee TEXT NOT NULL,
  liquidity_role TEXT,
  filled_at TEXT NOT NULL
);

CREATE TABLE positions (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  symbol TEXT NOT NULL,
  side TEXT NOT NULL,
  quantity TEXT NOT NULL,
  entry_price TEXT NOT NULL,
  realized_pnl TEXT NOT NULL,
  unrealized_pnl TEXT NOT NULL,
  captured_at TEXT NOT NULL
);

CREATE TABLE controlEvents (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  action TEXT NOT NULL,
  actor TEXT NOT NULL,
  previous_mode TEXT NOT NULL,
  new_mode TEXT NOT NULL,
  reason TEXT,
  created_at TEXT NOT NULL
);

CREATE TABLE alertEvents (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  sink TEXT NOT NULL,
  severity TEXT NOT NULL,
  title TEXT NOT NULL,
  delivery_status TEXT NOT NULL,
  failure_reason TEXT,
  created_at TEXT NOT NULL
);

CREATE TABLE performanceSnapshots (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  period TEXT NOT NULL,
  net_pnl TEXT NOT NULL,
  profit_factor TEXT,
  expectancy TEXT,
  max_drawdown TEXT,
  captured_at TEXT NOT NULL
);

selectBotState:
SELECT mode, updated_at, heartbeat_at
FROM botState
WHERE id = 1;

insertBotState:
INSERT INTO botState(id, mode, updated_at, heartbeat_at)
VALUES (1, ?, ?, ?);

updateBotState:
UPDATE botState
SET
  mode = ?,
  updated_at = ?,
  heartbeat_at = ?
WHERE id = 1;

insertControlEvent:
INSERT INTO controlEvents(
  action,
  actor,
  previous_mode,
  new_mode,
  reason,
  created_at
)
VALUES (?, ?, ?, ?, ?, ?);

selectRecentControlEvents:
SELECT id, action, actor, previous_mode, new_mode, reason, created_at
FROM controlEvents
ORDER BY id DESC
LIMIT ?;

insertAlertEvent:
INSERT INTO alertEvents(
  sink,
  severity,
  title,
  delivery_status,
  failure_reason,
  created_at
)
VALUES (?, ?, ?, ?, ?, ?);

countAlertEvents:
SELECT COUNT(*)
FROM alertEvents;

insertSignal:
INSERT INTO signals(
  strategy,
  symbol,
  side,
  score,
  grade,
  reason_codes,
  accepted,
  rejection_reason,
  created_at
)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?);

insertOrder:
INSERT INTO orders(
  exchange_order_id,
  client_order_id,
  signal_id,
  side,
  order_type,
  order_status,
  intended_risk,
  created_at
)
VALUES (?, ?, ?, ?, ?, ?, ?, ?);

insertFill:
INSERT INTO fills(
  order_id,
  fill_price,
  quantity,
  fee,
  liquidity_role,
  filled_at
)
VALUES (?, ?, ?, ?, ?, ?);

insertPosition:
INSERT INTO positions(
  symbol,
  side,
  quantity,
  entry_price,
  realized_pnl,
  unrealized_pnl,
  captured_at
)
VALUES (?, ?, ?, ?, ?, ?, ?);

insertPerformanceSnapshot:
INSERT INTO performanceSnapshots(
  period,
  net_pnl,
  profit_factor,
  expectancy,
  max_drawdown,
  captured_at
)
VALUES (?, ?, ?, ?, ?, ?);

lastInsertRowId:
SELECT last_insert_rowid();

selectLatestPerformanceSnapshot:
SELECT id, period, net_pnl, profit_factor, expectancy, max_drawdown, captured_at
FROM performanceSnapshots
ORDER BY id DESC
LIMIT 1;

selectRecentSignals:
SELECT id, strategy, symbol, side, score, grade, reason_codes, accepted, rejection_reason, created_at
FROM signals
ORDER BY id DESC
LIMIT ?;

selectRecentTrades:
SELECT
  orders.id AS order_id,
  orders.client_order_id,
  orders.signal_id,
  orders.side,
  orders.order_type,
  orders.order_status,
  orders.intended_risk,
  orders.created_at AS order_created_at,
  fills.id AS fill_id,
  fills.fill_price,
  fills.quantity,
  fills.fee,
  fills.filled_at
FROM orders
LEFT JOIN fills ON fills.order_id = orders.id
ORDER BY orders.id DESC
LIMIT ?;

upsertMarketCandle:
INSERT OR REPLACE INTO marketCandles(
  symbol,
  timeframe,
  opened_at,
  open,
  high,
  low,
  close,
  volume,
  source_timestamp
)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?);

selectRecentMarketCandles:
SELECT symbol, timeframe, opened_at, open, high, low, close, volume
FROM marketCandles
WHERE symbol = ? AND timeframe = ?
ORDER BY opened_at DESC
LIMIT ?;
