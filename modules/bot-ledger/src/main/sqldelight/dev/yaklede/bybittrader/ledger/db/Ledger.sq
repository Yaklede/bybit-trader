CREATE TABLE botState (
  id INTEGER NOT NULL PRIMARY KEY CHECK (id = 1),
  mode TEXT NOT NULL,
  updated_at TEXT NOT NULL,
  heartbeat_at TEXT
);

CREATE TABLE marketCandles (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  symbol TEXT NOT NULL,
  timeframe TEXT NOT NULL,
  opened_at TEXT NOT NULL,
  open TEXT NOT NULL,
  high TEXT NOT NULL,
  low TEXT NOT NULL,
  close TEXT NOT NULL,
  volume TEXT NOT NULL,
  source_timestamp TEXT NOT NULL
);

CREATE UNIQUE INDEX marketCandles_symbol_timeframe_openedAt_idx
ON marketCandles(symbol, timeframe, opened_at);

CREATE TABLE takerFlowBars (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  symbol TEXT NOT NULL,
  opened_at TEXT NOT NULL,
  taker_buy_base TEXT NOT NULL,
  taker_buy_notional TEXT NOT NULL,
  taker_sell_base TEXT NOT NULL,
  taker_sell_notional TEXT NOT NULL,
  buy_trade_count INTEGER NOT NULL,
  sell_trade_count INTEGER NOT NULL
);

CREATE UNIQUE INDEX takerFlowBars_symbol_openedAt_idx
ON takerFlowBars(symbol, opened_at);

CREATE TABLE openInterestSnapshots (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  symbol TEXT NOT NULL,
  interval TEXT NOT NULL,
  timestamp TEXT NOT NULL,
  open_interest TEXT NOT NULL
);

CREATE UNIQUE INDEX openInterestSnapshots_symbol_interval_timestamp_idx
ON openInterestSnapshots(symbol, interval, timestamp);

CREATE TABLE accountRatioSnapshots (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  symbol TEXT NOT NULL,
  period TEXT NOT NULL,
  timestamp TEXT NOT NULL,
  buy_ratio TEXT NOT NULL,
  sell_ratio TEXT NOT NULL
);

CREATE UNIQUE INDEX accountRatioSnapshots_symbol_period_timestamp_idx
ON accountRatioSnapshots(symbol, period, timestamp);

CREATE TABLE orderBookImbalanceBars (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  symbol TEXT NOT NULL,
  opened_at TEXT NOT NULL,
  sample_count INTEGER NOT NULL,
  mean_bid_notional TEXT NOT NULL,
  mean_ask_notional TEXT NOT NULL,
  mean_imbalance TEXT NOT NULL,
  mean_spread_bps TEXT NOT NULL,
  max_spread_bps TEXT NOT NULL
);

CREATE UNIQUE INDEX orderBookImbalanceBars_symbol_openedAt_idx
ON orderBookImbalanceBars(symbol, opened_at);

CREATE TABLE liquidationFlowBars (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  symbol TEXT NOT NULL,
  opened_at TEXT NOT NULL,
  long_liquidation_notional TEXT NOT NULL,
  short_liquidation_notional TEXT NOT NULL,
  long_liquidation_count INTEGER NOT NULL,
  short_liquidation_count INTEGER NOT NULL
);

CREATE UNIQUE INDEX liquidationFlowBars_symbol_openedAt_idx
ON liquidationFlowBars(symbol, opened_at);

CREATE TABLE premiumIndexBars (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  symbol TEXT NOT NULL,
  timeframe TEXT NOT NULL,
  opened_at TEXT NOT NULL,
  open TEXT NOT NULL,
  high TEXT NOT NULL,
  low TEXT NOT NULL,
  close TEXT NOT NULL
);

CREATE UNIQUE INDEX premiumIndexBars_symbol_timeframe_openedAt_idx
ON premiumIndexBars(symbol, timeframe, opened_at);

CREATE TABLE fundingRates (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  symbol TEXT NOT NULL,
  timestamp TEXT NOT NULL,
  funding_rate TEXT NOT NULL
);

CREATE UNIQUE INDEX fundingRates_symbol_timestamp_idx
ON fundingRates(symbol, timestamp);

CREATE TABLE signals (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  strategy TEXT NOT NULL,
  symbol TEXT NOT NULL,
  side TEXT NOT NULL,
  score INTEGER NOT NULL,
  grade TEXT NOT NULL,
  reason_codes TEXT NOT NULL,
  accepted INTEGER NOT NULL,
  rejection_reason TEXT,
  created_at TEXT NOT NULL
);

CREATE TABLE orders (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  exchange_order_id TEXT,
  client_order_id TEXT NOT NULL UNIQUE,
  signal_id INTEGER,
  side TEXT NOT NULL,
  order_type TEXT NOT NULL,
  order_status TEXT NOT NULL,
  intended_risk TEXT NOT NULL,
  created_at TEXT NOT NULL
);

CREATE TABLE fills (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  order_id INTEGER NOT NULL,
  fill_price TEXT NOT NULL,
  quantity TEXT NOT NULL,
  fee TEXT NOT NULL,
  liquidity_role TEXT,
  filled_at TEXT NOT NULL
);

CREATE TABLE positions (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  symbol TEXT NOT NULL,
  side TEXT NOT NULL,
  quantity TEXT NOT NULL,
  entry_price TEXT NOT NULL,
  realized_pnl TEXT NOT NULL,
  unrealized_pnl TEXT NOT NULL,
  captured_at TEXT NOT NULL
);

CREATE TABLE controlEvents (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  action TEXT NOT NULL,
  actor TEXT NOT NULL,
  previous_mode TEXT NOT NULL,
  new_mode TEXT NOT NULL,
  reason TEXT,
  created_at TEXT NOT NULL
);

CREATE TABLE alertEvents (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  sink TEXT NOT NULL,
  severity TEXT NOT NULL,
  title TEXT NOT NULL,
  delivery_status TEXT NOT NULL,
  failure_reason TEXT,
  created_at TEXT NOT NULL
);

CREATE TABLE performanceSnapshots (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  period TEXT NOT NULL,
  net_pnl TEXT NOT NULL,
  profit_factor TEXT,
  expectancy TEXT,
  max_drawdown TEXT,
  captured_at TEXT NOT NULL
);

CREATE TABLE marketSyncCheckpoints (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  symbol TEXT NOT NULL,
  timeframe TEXT NOT NULL,
  latest_closed_opened_at TEXT NOT NULL,
  last_sync_at TEXT NOT NULL,
  last_sync_status TEXT NOT NULL,
  consecutive_rate_limit_count INTEGER NOT NULL
);

CREATE UNIQUE INDEX marketSyncCheckpoints_symbol_timeframe_idx
ON marketSyncCheckpoints(symbol, timeframe);

CREATE TABLE executionTradeClosures (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  mode TEXT NOT NULL,
  symbol TEXT NOT NULL,
  side TEXT NOT NULL,
  opened_at TEXT NOT NULL,
  closed_at TEXT NOT NULL,
  entry_price TEXT NOT NULL,
  exit_price TEXT NOT NULL,
  quantity TEXT NOT NULL,
  gross_pnl TEXT NOT NULL,
  fees TEXT NOT NULL,
  net_pnl TEXT NOT NULL,
  exit_reason TEXT NOT NULL,
  exchange_order_id TEXT,
  client_order_id TEXT,
  identity_key TEXT NOT NULL,
  delivered_at TEXT,
  suppressed_at TEXT,
  attempt_count INTEGER NOT NULL DEFAULT 0,
  last_attempt_at TEXT
);

CREATE UNIQUE INDEX executionTradeClosures_identity_idx
ON executionTradeClosures(identity_key);

CREATE INDEX executionTradeClosures_symbol_mode_id_idx
ON executionTradeClosures(symbol, mode, id DESC);

CREATE TABLE livePerformanceSnapshots (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  mode TEXT NOT NULL,
  window TEXT NOT NULL,
  trade_count INTEGER NOT NULL,
  win_rate_pct TEXT NOT NULL,
  gross_profit TEXT NOT NULL,
  gross_loss TEXT NOT NULL,
  fees TEXT NOT NULL,
  net_pnl TEXT NOT NULL,
  profit_factor TEXT,
  expectancy TEXT,
  max_closed_trade_drawdown_pct TEXT NOT NULL,
  last_closed_at TEXT,
  captured_at TEXT NOT NULL
);

CREATE INDEX livePerformanceSnapshots_mode_window_id_idx
ON livePerformanceSnapshots(mode, window, id DESC);

selectBotState:
SELECT mode, updated_at, heartbeat_at
FROM botState
WHERE id = 1;

insertBotState:
INSERT INTO botState(id, mode, updated_at, heartbeat_at)
VALUES (1, ?, ?, ?);

updateBotState:
UPDATE botState
SET
  mode = ?,
  updated_at = ?,
  heartbeat_at = ?
WHERE id = 1;

insertControlEvent:
INSERT INTO controlEvents(
  action,
  actor,
  previous_mode,
  new_mode,
  reason,
  created_at
)
VALUES (?, ?, ?, ?, ?, ?);

selectRecentControlEvents:
SELECT id, action, actor, previous_mode, new_mode, reason, created_at
FROM controlEvents
ORDER BY id DESC
LIMIT ?;

insertAlertEvent:
INSERT INTO alertEvents(
  sink,
  severity,
  title,
  delivery_status,
  failure_reason,
  created_at
)
VALUES (?, ?, ?, ?, ?, ?);

countAlertEvents:
SELECT COUNT(*)
FROM alertEvents;

insertSignal:
INSERT INTO signals(
  strategy,
  symbol,
  side,
  score,
  grade,
  reason_codes,
  accepted,
  rejection_reason,
  created_at
)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?);

insertOrder:
INSERT INTO orders(
  exchange_order_id,
  client_order_id,
  signal_id,
  side,
  order_type,
  order_status,
  intended_risk,
  created_at
)
VALUES (?, ?, ?, ?, ?, ?, ?, ?);

insertFill:
INSERT INTO fills(
  order_id,
  fill_price,
  quantity,
  fee,
  liquidity_role,
  filled_at
)
VALUES (?, ?, ?, ?, ?, ?);

insertPosition:
INSERT INTO positions(
  symbol,
  side,
  quantity,
  entry_price,
  realized_pnl,
  unrealized_pnl,
  captured_at
)
VALUES (?, ?, ?, ?, ?, ?, ?);

insertPerformanceSnapshot:
INSERT INTO performanceSnapshots(
  period,
  net_pnl,
  profit_factor,
  expectancy,
  max_drawdown,
  captured_at
)
VALUES (?, ?, ?, ?, ?, ?);

lastInsertRowId:
SELECT last_insert_rowid();

selectChanges:
SELECT changes();

selectLatestPerformanceSnapshot:
SELECT id, period, net_pnl, profit_factor, expectancy, max_drawdown, captured_at
FROM performanceSnapshots
ORDER BY id DESC
LIMIT 1;

selectRecentSignals:
SELECT id, strategy, symbol, side, score, grade, reason_codes, accepted, rejection_reason, created_at
FROM signals
ORDER BY id DESC
LIMIT ?;

selectRecentTrades:
SELECT
  orders.id AS order_id,
  orders.client_order_id,
  orders.signal_id,
  orders.side,
  orders.order_type,
  orders.order_status,
  orders.intended_risk,
  orders.created_at AS order_created_at,
  fills.id AS fill_id,
  fills.fill_price,
  fills.quantity,
  fills.fee,
  fills.filled_at
FROM orders
LEFT JOIN fills ON fills.order_id = orders.id
ORDER BY orders.id DESC
LIMIT ?;

upsertMarketCandle:
INSERT OR REPLACE INTO marketCandles(
  symbol,
  timeframe,
  opened_at,
  open,
  high,
  low,
  close,
  volume,
  source_timestamp
)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?);

selectRecentMarketCandles:
SELECT symbol, timeframe, opened_at, open, high, low, close, volume
FROM marketCandles
WHERE symbol = ? AND timeframe = ?
ORDER BY opened_at DESC
LIMIT ?;

selectMarketCandlesBetween:
SELECT symbol, timeframe, opened_at, open, high, low, close, volume
FROM marketCandles
WHERE symbol = :symbol
  AND timeframe = :timeframe
  AND opened_at >= :startAt
  AND opened_at <= :endAt
ORDER BY opened_at DESC
LIMIT :limit;

selectMarketCandlesBefore:
SELECT symbol, timeframe, opened_at, open, high, low, close, volume
FROM marketCandles
WHERE symbol = :symbol
  AND timeframe = :timeframe
  AND opened_at < :beforeAt
ORDER BY opened_at DESC
LIMIT :limit;

upsertTakerFlowBar:
INSERT OR REPLACE INTO takerFlowBars(
  id,
  symbol,
  opened_at,
  taker_buy_base,
  taker_buy_notional,
  taker_sell_base,
  taker_sell_notional,
  buy_trade_count,
  sell_trade_count
)
VALUES (
  (SELECT id FROM takerFlowBars WHERE symbol = :symbol AND opened_at = :opened_at),
  :symbol,
  :opened_at,
  :taker_buy_base,
  :taker_buy_notional,
  :taker_sell_base,
  :taker_sell_notional,
  :buy_trade_count,
  :sell_trade_count
);

selectTakerFlowBarsBetween:
SELECT symbol, opened_at, taker_buy_base, taker_buy_notional, taker_sell_base, taker_sell_notional,
  buy_trade_count, sell_trade_count
FROM takerFlowBars
WHERE symbol = :symbol
  AND opened_at >= :startAt
  AND opened_at <= :endAt
ORDER BY opened_at ASC
LIMIT :limit;

selectTakerFlowBarsBefore:
SELECT symbol, opened_at, taker_buy_base, taker_buy_notional, taker_sell_base, taker_sell_notional,
  buy_trade_count, sell_trade_count
FROM takerFlowBars
WHERE symbol = :symbol
  AND opened_at < :beforeAt
ORDER BY opened_at DESC
LIMIT :limit;

upsertOpenInterestSnapshot:
INSERT OR REPLACE INTO openInterestSnapshots(
  id,
  symbol,
  interval,
  timestamp,
  open_interest
)
VALUES (
  (SELECT id FROM openInterestSnapshots WHERE symbol = :symbol AND interval = :interval AND timestamp = :timestamp),
  :symbol,
  :interval,
  :timestamp,
  :open_interest
);

selectOpenInterestSnapshotsBetween:
SELECT symbol, interval, timestamp, open_interest
FROM openInterestSnapshots
WHERE symbol = :symbol
  AND interval = :interval
  AND timestamp >= :startAt
  AND timestamp <= :endAt
ORDER BY timestamp ASC
LIMIT :limit;

selectOpenInterestSnapshotsBefore:
SELECT symbol, interval, timestamp, open_interest
FROM openInterestSnapshots
WHERE symbol = :symbol
  AND interval = :interval
  AND timestamp < :beforeAt
ORDER BY timestamp DESC
LIMIT :limit;

upsertAccountRatioSnapshot:
INSERT OR REPLACE INTO accountRatioSnapshots(
  id,
  symbol,
  period,
  timestamp,
  buy_ratio,
  sell_ratio
)
VALUES (
  (SELECT id FROM accountRatioSnapshots WHERE symbol = :symbol AND period = :period AND timestamp = :timestamp),
  :symbol,
  :period,
  :timestamp,
  :buy_ratio,
  :sell_ratio
);

selectAccountRatioSnapshotsBetween:
SELECT symbol, period, timestamp, buy_ratio, sell_ratio
FROM accountRatioSnapshots
WHERE symbol = :symbol
  AND period = :period
  AND timestamp >= :startAt
  AND timestamp <= :endAt
ORDER BY timestamp ASC
LIMIT :limit;

selectAccountRatioSnapshotsBefore:
SELECT symbol, period, timestamp, buy_ratio, sell_ratio
FROM accountRatioSnapshots
WHERE symbol = :symbol
  AND period = :period
  AND timestamp < :beforeAt
ORDER BY timestamp DESC
LIMIT :limit;

upsertOrderBookImbalanceBar:
INSERT OR REPLACE INTO orderBookImbalanceBars(
  id,
  symbol,
  opened_at,
  sample_count,
  mean_bid_notional,
  mean_ask_notional,
  mean_imbalance,
  mean_spread_bps,
  max_spread_bps
)
VALUES (
  (SELECT id FROM orderBookImbalanceBars WHERE symbol = :symbol AND opened_at = :opened_at),
  :symbol,
  :opened_at,
  :sample_count,
  :mean_bid_notional,
  :mean_ask_notional,
  :mean_imbalance,
  :mean_spread_bps,
  :max_spread_bps
);

selectOrderBookImbalanceBarsBetween:
SELECT symbol, opened_at, sample_count, mean_bid_notional, mean_ask_notional, mean_imbalance, mean_spread_bps, max_spread_bps
FROM orderBookImbalanceBars
WHERE symbol = :symbol
  AND opened_at >= :startAt
  AND opened_at <= :endAt
ORDER BY opened_at ASC
LIMIT :limit;

upsertLiquidationFlowBar:
INSERT OR REPLACE INTO liquidationFlowBars(
  id,
  symbol,
  opened_at,
  long_liquidation_notional,
  short_liquidation_notional,
  long_liquidation_count,
  short_liquidation_count
)
VALUES (
  (SELECT id FROM liquidationFlowBars WHERE symbol = :symbol AND opened_at = :opened_at),
  :symbol,
  :opened_at,
  :long_liquidation_notional,
  :short_liquidation_notional,
  :long_liquidation_count,
  :short_liquidation_count
);

selectLiquidationFlowBarsBetween:
SELECT symbol, opened_at, long_liquidation_notional, short_liquidation_notional, long_liquidation_count, short_liquidation_count
FROM liquidationFlowBars
WHERE symbol = :symbol
  AND opened_at >= :startAt
  AND opened_at <= :endAt
ORDER BY opened_at ASC
LIMIT :limit;

upsertPremiumIndexBar:
INSERT OR REPLACE INTO premiumIndexBars(
  id,
  symbol,
  timeframe,
  opened_at,
  open,
  high,
  low,
  close
)
VALUES (
  (SELECT id FROM premiumIndexBars WHERE symbol = :symbol AND timeframe = :timeframe AND opened_at = :opened_at),
  :symbol,
  :timeframe,
  :opened_at,
  :open,
  :high,
  :low,
  :close
);

selectPremiumIndexBarsBetween:
SELECT symbol, timeframe, opened_at, open, high, low, close
FROM premiumIndexBars
WHERE symbol = :symbol
  AND timeframe = :timeframe
  AND opened_at >= :startAt
  AND opened_at <= :endAt
ORDER BY opened_at ASC
LIMIT :limit;

selectPremiumIndexBarsBefore:
SELECT symbol, timeframe, opened_at, open, high, low, close
FROM premiumIndexBars
WHERE symbol = :symbol
  AND timeframe = :timeframe
  AND opened_at < :beforeAt
ORDER BY opened_at DESC
LIMIT :limit;

upsertFundingRateSnapshot:
INSERT OR REPLACE INTO fundingRates(
  id,
  symbol,
  timestamp,
  funding_rate
)
VALUES (
  (SELECT id FROM fundingRates WHERE symbol = :symbol AND timestamp = :timestamp),
  :symbol,
  :timestamp,
  :funding_rate
);

selectFundingRateSnapshotsBetween:
SELECT symbol, timestamp, funding_rate
FROM fundingRates
WHERE symbol = :symbol
  AND timestamp >= :startAt
  AND timestamp <= :endAt
ORDER BY timestamp ASC
LIMIT :limit;

selectFundingRateSnapshotsBefore:
SELECT symbol, timestamp, funding_rate
FROM fundingRates
WHERE symbol = :symbol
  AND timestamp < :beforeAt
ORDER BY timestamp DESC
LIMIT :limit;

upsertMarketSyncCheckpoint:
INSERT OR REPLACE INTO marketSyncCheckpoints(
  id,
  symbol,
  timeframe,
  latest_closed_opened_at,
  last_sync_at,
  last_sync_status,
  consecutive_rate_limit_count
)
VALUES (
  (SELECT id FROM marketSyncCheckpoints WHERE symbol = ? AND timeframe = ?),
  ?, ?, ?, ?, ?, ?
);

selectMarketSyncCheckpoints:
SELECT symbol, timeframe, latest_closed_opened_at, last_sync_at, last_sync_status, consecutive_rate_limit_count
FROM marketSyncCheckpoints
WHERE symbol = ?
ORDER BY timeframe ASC;

insertExecutionTradeClosure:
INSERT OR IGNORE INTO executionTradeClosures(
  mode,
  symbol,
  side,
  opened_at,
  closed_at,
  entry_price,
  exit_price,
  quantity,
  gross_pnl,
  fees,
  net_pnl,
  exit_reason,
  exchange_order_id,
  client_order_id,
  identity_key,
  suppressed_at
)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

selectClosedTrades:
SELECT id, mode, symbol, side, opened_at, closed_at, entry_price, exit_price, quantity, gross_pnl, fees, net_pnl,
  exit_reason, exchange_order_id, client_order_id, identity_key, delivered_at, suppressed_at, attempt_count, last_attempt_at
FROM executionTradeClosures
WHERE (:symbol IS NULL OR symbol = :symbol)
  AND (:mode IS NULL OR mode = :mode)
  AND (:cursor IS NULL OR id < :cursor)
ORDER BY id DESC
LIMIT :limit;

selectLatestClosedTradeBySymbol:
SELECT id, mode, symbol, side, opened_at, closed_at, entry_price, exit_price, quantity, gross_pnl, fees, net_pnl,
  exit_reason, exchange_order_id, client_order_id, identity_key, delivered_at, suppressed_at, attempt_count, last_attempt_at
FROM executionTradeClosures
WHERE symbol = ?
ORDER BY id DESC
LIMIT 1;

selectPerformanceClosures:
SELECT id, mode, symbol, side, opened_at, closed_at, entry_price, exit_price, quantity, gross_pnl, fees, net_pnl,
  exit_reason, exchange_order_id, client_order_id, identity_key, delivered_at, suppressed_at, attempt_count, last_attempt_at
FROM executionTradeClosures
WHERE mode = :mode
  AND (:closedAtOrAfter IS NULL OR closed_at >= :closedAtOrAfter)
ORDER BY closed_at ASC, id ASC;

selectClosureHistoryId:
SELECT id
FROM executionTradeClosures
WHERE mode = :mode
  AND symbol = :symbol
LIMIT 1;

selectPendingClosureAlerts:
SELECT id, mode, symbol, side, opened_at, closed_at, entry_price, exit_price, quantity, gross_pnl, fees, net_pnl,
  exit_reason, exchange_order_id, client_order_id, identity_key, delivered_at, suppressed_at, attempt_count, last_attempt_at
FROM executionTradeClosures
WHERE mode = :mode
  AND symbol = :symbol
  AND delivered_at IS NULL
  AND suppressed_at IS NULL
ORDER BY closed_at ASC, id ASC
LIMIT :limit;

recordFailedClosureAlertAttempt:
UPDATE executionTradeClosures
SET attempt_count = attempt_count + 1,
  last_attempt_at = :attemptedAt
WHERE id = :closureId;

recordDeliveredClosureAlertAttempt:
UPDATE executionTradeClosures
SET delivered_at = :attemptedAt,
  attempt_count = attempt_count + 1,
  last_attempt_at = :attemptedAt
WHERE id = :closureId;

insertLivePerformanceSnapshot:
INSERT INTO livePerformanceSnapshots(
  mode,
  window,
  trade_count,
  win_rate_pct,
  gross_profit,
  gross_loss,
  fees,
  net_pnl,
  profit_factor,
  expectancy,
  max_closed_trade_drawdown_pct,
  last_closed_at,
  captured_at
)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

selectLatestLivePerformanceSnapshot:
SELECT id, mode, window, trade_count, win_rate_pct, gross_profit, gross_loss, fees, net_pnl, profit_factor, expectancy,
  max_closed_trade_drawdown_pct, last_closed_at, captured_at
FROM livePerformanceSnapshots
WHERE (:mode IS NULL OR mode = :mode)
  AND window = :window
ORDER BY id DESC
LIMIT 1;
